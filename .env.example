# ============================================================================
# pre-RICHARD-tion.fun — environment variables template
# ============================================================================
# DO NOT put real values in this file.  This file IS committed to git as a
# reference for which env vars the app needs.
#
# Real values live in:
#   - Render dashboard for production (https://dashboard.render.com)
#   - .env.local on your laptop for local development (gitignored)
#
# If you ever find yourself filling in real values here, STOP — you're
# about to commit secrets.  Use .env.local instead.
# ============================================================================

# --- BACKEND (Render) ---

# Solana RPC endpoint (Helius).  Get a key at https://dashboard.helius.dev
# Format: https://mainnet.helius-rpc.com/?api-key=<your-key>
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# Supabase project URL — found in Supabase dashboard → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Supabase service_role key — has full DB access.  TREAT AS SECRET.
# Found in Supabase dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=eyJ_YOUR_KEY_HERE

# Escrow authority private key (base58).  TREAT AS SECRET — anyone with this
# can drain the escrow.  This was leaked once already (see incident: v49).
# Generate a new one in Phantom: + Add Account → Create New → Export Private Key
ESCROW_AUTHORITY_SECRET=YOUR_BASE58_PRIVATE_KEY

# Random string used to authenticate cron-job.org calls to /api/admin/*
# Just any 32+ char alphanumeric string.  Must match cron-job.org headers.
ADMIN_API_KEY=YOUR_RANDOM_STRING_AT_LEAST_32_CHARS

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=https://pre-richard-tion.fun,http://localhost:5173

# Where the platform fee goes (3% of payouts).  Public Solana address.
PLATFORM_FEE_WALLET=YOUR_PUBLIC_ADDRESS

# TROLL token mint — public Solana address
TROLL_MINT=5UUH9RTDiSpq6HKS6bp4NdU9PNJpXRXuiw6ShBTBhgH2

# Misc
NODE_ENV=production
SERVER_PORT=8787
DEXSCREENER_PAIR_URL=https://api.dexscreener.com/latest/dex/pairs/solana/YOUR_PAIR

# --- FRONTEND (Vercel) — only VITE_-prefixed vars are exposed to browser ---

# These are PUBLIC by design — they get bundled into the JS shipped to users.
# NEVER put secrets in VITE_-prefixed vars.

VITE_API_BASE_URL=https://pre-richard-tion-api.onrender.com
VITE_TROLL_MINT=5UUH9RTDiSpq6HKS6bp4NdU9PNJpXRXuiw6ShBTBhgH2
VITE_DEXSCREENER_PAIR_URL=https://dexscreener.com/solana/YOUR_PAIR
VITE_GECKOTERMINAL_POOL_URL=https://www.geckoterminal.com/solana/pools/YOUR_POOL
