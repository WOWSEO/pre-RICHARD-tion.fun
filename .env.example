# =============================================================================
# prerichardtion.fun — environment variables
#
# Two audiences:
#   1. Local dev    — copy this file to .env, fill in values, run `npm run dev`
#                     and `npm run dev:server`.
#   2. Production   — set these in your Netlify / Render / Railway dashboards.
#                     See DEPLOYMENT.md for the step-by-step.
# =============================================================================


# =============================================================================
# CLIENT (Vite)  —  every var prefixed VITE_* is shipped in the browser bundle.
# In production, these are set in the Netlify dashboard under
# Site settings → Environment variables.
# =============================================================================

# Solana mint address of the $TROLL token.  Required.
VITE_TROLL_MINT=

# Helius / Solana RPC URL — used for getTokenAccountsByOwner balance queries
# and for broadcasting the user's signed transferChecked transaction.
# Example: https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
VITE_HELIUS_RPC_URL=

# DexScreener pair URL — drives the embedded chart and the live MC card.
# Example: https://dexscreener.com/solana/<pairAddress>
VITE_DEXSCREENER_PAIR_URL=

# GeckoTerminal pool URL — fallback chart embed and MC source.
# Example: https://www.geckoterminal.com/solana/pools/<poolAddress>
VITE_GECKOTERMINAL_POOL_URL=

# Base URL of the prerichardtion.fun API.
# - LOCAL DEV:  leave unset — apiClient defaults to "/api" and the Vite dev
#   server (vite.config.ts) proxies /api → http://localhost:8787.
# - PRODUCTION: REQUIRED — set to your Render/Railway https URL, e.g.
#   https://prerichardtion-api.onrender.com   (no trailing slash)
# VITE_API_BASE_URL=https://prerichardtion-api.onrender.com


# =============================================================================
# SERVER (Express)  —  NEVER expose these to the browser.
# In production, set these in the Render / Railway dashboard.
# `npm run server` reads them from process.env.
# =============================================================================

# Port the API listens on.
# - LOCAL DEV:  set SERVER_PORT (preferred) or PORT.  Defaults to 8787.
# - PRODUCTION: Render and Railway inject PORT automatically.  Don't override
#               unless you have a specific reason.
SERVER_PORT=8787
# PORT (legacy alias for SERVER_PORT) — still accepted but prefer SERVER_PORT

# Allowed browser origins for CORS — comma-separated, no trailing slash.
# - LOCAL DEV:  defaults handle localhost:5173 + 5174 already; you can leave
#               this unset.
# - PRODUCTION: list every public hostname for the Netlify site, including
#               the bare apex AND www subdomain.  When unset, the server
#               defaults to:
#                 https://pre-richard-tion.fun,
#                 https://www.pre-richard-tion.fun,
#                 http://localhost:5173,
#                 http://localhost:5174
#               which already covers the production deployment.  Override
#               only if your Netlify domain differs.
# CLIENT_ORIGIN=https://pre-richard-tion.fun,https://www.pre-richard-tion.fun

# Anyone with this key can create/void/settle markets and trigger payouts.
# Use a long random string in production (e.g., `openssl rand -hex 32`).
# REQUIRED.
ADMIN_API_KEY=

# Supabase project URL + service-role key (NOT the anon key — service-role
# bypasses RLS, which the server depends on for writes).
# REQUIRED.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Server-side Solana RPC URL — same value as VITE_HELIUS_RPC_URL is fine for
# dev; in production use a separate higher-tier key so the server isn't
# rate-limited together with browser clients.  REQUIRED.
HELIUS_RPC_URL=

# $TROLL mint, server-side.  Same value as VITE_TROLL_MINT.  REQUIRED.
TROLL_MINT=

# Base58-encoded 64-byte secret key of the escrow authority Keypair.
# Generate with `solana-keygen new --outfile escrow.json` and convert to
# base58 (see DEPLOYMENT.md "Generate the escrow keypair" for exact commands).
# NEVER commit this.  NEVER share it.  REQUIRED.
ESCROW_AUTHORITY_SECRET=

# Optional: pin a specific token account as the escrow ATA.  If unset, the
# server derives ATA(TROLL_MINT, ESCROW_AUTHORITY) automatically.
# ESCROW_TOKEN_ACCOUNT_OVERRIDE=

# Confirmation level for deposit verification: processed | confirmed | finalized
# Defaults to confirmed.  Production: leave at confirmed unless you've
# explicitly weighed the trade-offs.
DEPOSIT_CONFIRMATION=confirmed
