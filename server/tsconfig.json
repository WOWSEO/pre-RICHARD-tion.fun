{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "lib": ["ES2022"],
    "types": ["node"],
    "allowImportingTsExtensions": false
  },
  "include": ["**/*.ts", "../src/market/**/*", "../src/config/**/*", "../src/providers/**/*"]
}
