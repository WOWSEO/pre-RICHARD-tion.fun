{
  "name": "prerichardtion-fun",
  "version": "0.4.0",
  "private": true,
  "description": "prerichardtion.fun — $TROLL-only YES/NO prediction market. Real escrow, server-side state, Phantom signing.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "tsc -b && vite build",
    "build:server": "tsc -p server/tsconfig.json",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "simulate": "tsx src/simulation/runTrollSimulation.ts",
    "server": "tsx server/index.ts",
    "settle": "tsx server/workers/settle.ts",
    "seed:markets": "tsx server/workers/seedMarkets.ts",
    "payouts:run": "tsx server/workers/payouts.ts",
    "tick:markets": "tsx server/workers/tickMarkets.ts",
    "seed:markets:manual": "tsx server/workers/seedMarketsManual.ts",
    "typecheck": "tsc -b --noEmit && tsc -p server/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@solana/spl-token": "^0.4.9",
    "@solana/wallet-adapter-base": "^0.9.27",
    "@solana/wallet-adapter-react": "^0.15.39",
    "@solana/wallet-adapter-react-ui": "^0.9.39",
    "@solana/wallet-adapter-wallets": "^0.19.37",
    "@solana/web3.js": "^1.95.8",
    "@supabase/supabase-js": "^2.46.1",
    "bs58": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/node": "^20.19.39",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "buffer": "^6.0.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vite": "^5.4.10",
    "vitest": "^1.4.0"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1"
  }
}
